#!/bin/bash
# localdev launcher - lightweight container (no Java, single Node LTS) - DEFAULT

DIR_NAME=$(basename "$(pwd)")

VOLUME_MOUNTS=()
DEVICE_MOUNTS=()
MOUNT_ERRORS=0
MOUNTS_CONTENT="# localdev mount map\n# HOST PATH -> CONTAINER PATH (mode)\n"

add_device_mount() {
  local path="$1"
  if [[ ! -e "$path" ]]; then
    echo "Warning: Skipping non-existent device '$path'" >&2
    return 1
  fi
  if [[ ! -c "$path" && ! -b "$path" ]]; then
    echo "Warning: '$path' is not a device file (not char or block device)" >&2
    return 1
  fi
  if [[ ! -r "$path" ]]; then
    echo "Warning: Skipping unreadable device '$path' (permission denied)" >&2
    ((MOUNT_ERRORS++))
    return 1
  fi
  DEVICE_MOUNTS+=("--device" "$path")
  echo "Device passthrough:    $path" >&2
}

resolve_path() {
  local path="$1"
  if [[ ! "$path" = /* ]]; then
    path="$(cd "$(dirname "$path")" 2>/dev/null && pwd)/$(basename "$path")"
    if [[ $? -ne 0 ]]; then
      echo "Warning: Cannot resolve path '$1'" >&2
      return 1
    fi
  fi
  if [[ ! -d "$path" ]]; then
    echo "Warning: Skipping non-existent directory '$path'" >&2
    return 1
  fi
  if command -v realpath >/dev/null 2>&1; then
    path=$(realpath "$path" 2>/dev/null) || path=$(python3 -c "import os; print(os.path.realpath('$path'))" 2>/dev/null)
  else
    path=$(python3 -c "import os; print(os.path.realpath('$path'))" 2>/dev/null)
  fi
  if [[ -z "$path" ]]; then
    echo "Warning: Cannot normalize path '$1'" >&2
    return 1
  fi
  echo "$path"
}

add_ro_mount() {
  local path
  path=$(resolve_path "$1") || return 1
  if [[ ! -r "$path" ]]; then
    echo "Warning: Skipping unreadable directory '$path' (permission denied)" >&2
    ((MOUNT_ERRORS++))
    return 1
  fi
  local dir_name
  dir_name=$(basename "$path")
  VOLUME_MOUNTS+=("-v" "${path}:/external/${dir_name}:ro")
  echo "Mounting (read-only):  $path -> /external/${dir_name}" >&2
  MOUNTS_CONTENT+="$path -> /external/${dir_name} (read-only)\n"
}

add_rw_mount() {
  local path
  path=$(resolve_path "$1") || return 1
  if [[ ! -r "$path" ]]; then
    echo "Warning: Skipping unreadable directory '$path' (permission denied)" >&2
    ((MOUNT_ERRORS++))
    return 1
  fi
  local dir_name
  dir_name=$(basename "$path")
  VOLUME_MOUNTS+=("-v" "${path}:/external/${dir_name}:rw")
  echo "Mounting (read-write): $path -> /external/${dir_name}" >&2
  MOUNTS_CONTENT+="$path -> /external/${dir_name} (read-write)\n"
}

# Process command-line arguments.
# Flags: -rw <path> mounts read-write, -ro <path> or bare <path> mounts read-only.
# /dev/* paths are always treated as device passthroughs regardless of flag.
args=("$@")
i=0
while [[ $i -lt ${#args[@]} ]]; do
  arg="${args[$i]}"
  if [[ "$arg" == "-rw" || "$arg" == "-ro" ]]; then
    ((i++))
    if [[ $i -ge ${#args[@]} ]]; then
      echo "Error: $arg requires a path argument" >&2
      exit 1
    fi
    next="${args[$i]}"
    if [[ "$next" == /dev/* ]]; then
      add_device_mount "$next"
    elif [[ "$arg" == "-rw" ]]; then
      add_rw_mount "$next"
    else
      add_ro_mount "$next"
    fi
  elif [[ "$arg" == /dev/* ]]; then
    add_device_mount "$arg"
  else
    add_ro_mount "$arg"
  fi
  ((i++))
done

# Process LOCALDEV_MOUNTS environment variable.
# Format: semicolon-separated entries. Prefix with rw: for read-write, ro: or no prefix for read-only.
# Example: export LOCALDEV_MOUNTS="rw:/path/to/writable;/path/to/readonly"
if [[ -n "$LOCALDEV_MOUNTS" ]]; then
  IFS=';' read -ra MOUNT_PATHS <<< "$LOCALDEV_MOUNTS"
  for entry in "${MOUNT_PATHS[@]}"; do
    entry=$(echo "$entry" | xargs)
    [[ -z "$entry" ]] && continue
    if [[ "$entry" == rw:* ]]; then
      path="${entry#rw:}"
      if [[ "$path" == /dev/* ]]; then
        add_device_mount "$path"
      else
        add_rw_mount "$path"
      fi
    else
      path="${entry#ro:}"
      if [[ "$path" == /dev/* ]]; then
        add_device_mount "$path"
      else
        add_ro_mount "$path"
      fi
    fi
  done
fi

if [[ ! -r "$(pwd)" ]]; then
  echo "Error: Current directory is not readable. Cannot mount workspace." >&2
  exit 1
fi

# Handle dotfiles directory mount for stow
DOTFILES_MOUNT=()
if [[ -d "$HOME/dotfiles" ]]; then
  if [[ -r "$HOME/dotfiles" ]]; then
    DOTFILES_MOUNT=("-v" "$HOME/dotfiles:/external/dotfiles:ro")
    echo "Mounting (read-only):  $HOME/dotfiles -> /external/dotfiles" >&2
    MOUNTS_CONTENT+="$HOME/dotfiles -> /external/dotfiles (read-only)\n"
  else
    echo "Warning: $HOME/dotfiles exists but is not readable, skipping mount" >&2
    ((MOUNT_ERRORS++))
  fi
fi

# Handle .claude directory mount (native location for Claude Code global config)
mkdir -p "$HOME/.claude" 2>/dev/null || true
CLAUDE_MOUNT=()
if [[ -d "$HOME/.claude" ]]; then
  if [[ -r "$HOME/.claude" ]]; then
    CLAUDE_MOUNT=("-v" "$HOME/.claude:/home/developer/.claude:rw")
    echo "Mounting (read-write): $HOME/.claude -> /home/developer/.claude" >&2
    MOUNTS_CONTENT+="$HOME/.claude -> /home/developer/.claude (read-write)\n"
  else
    echo "Warning: $HOME/.claude exists but is not readable, skipping mount" >&2
    ((MOUNT_ERRORS++))
  fi
else
  echo "Info: $HOME/.claude could not be created, skipping mount" >&2
fi

# Handle npm cache directory mount for faster npx (Claude Code auto-updates)
NPM_CACHE_DIR="$HOME/.npm-cache-localdev"
mkdir -p "$NPM_CACHE_DIR" 2>/dev/null || true
NPM_CACHE_MOUNT=()
if [[ -d "$NPM_CACHE_DIR" ]] && [[ -w "$NPM_CACHE_DIR" ]]; then
  NPM_CACHE_MOUNT=("-v" "$NPM_CACHE_DIR:/home/developer/.npm:rw")
  echo "Mounting (read-write): $NPM_CACHE_DIR -> /home/developer/.npm" >&2
else
  echo "Info: npm cache mount unavailable, npx will be slower on first use" >&2
fi

if [[ $MOUNT_ERRORS -gt 0 ]]; then
  echo "Warning: $MOUNT_ERRORS mount(s) skipped due to permission issues" >&2
fi

# Detect if podman is in remote mode
IS_REMOTE=$(podman info --format json 2>/dev/null | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    print('true' if data.get('host', {}).get('serviceIsRemote', False) else 'false')
except:
    print('false')
" 2>/dev/null)

GROUP_ADD_FLAG=()
if [[ "$IS_REMOTE" != "true" ]]; then
  GROUP_ADD_FLAG=("--group-add" "keep-groups")
fi

# --userns=keep-id on Linux triggers slow ID-mapped layer copies when host UID != container UID.
# Skip it on Linux when the host UID already matches the container developer UID (1000).
USERNS_FLAG=()
if [[ "$(uname -s)" == "Linux" && "$(id -u)" == "1000" ]]; then
  echo "Info: Skipping --userns=keep-id on Linux (host UID matches container UID 1000)" >&2
else
  USERNS_FLAG=("--userns=keep-id")
fi

USB_DEVICE_FLAG=()
if [[ -d "/dev/bus/usb" ]]; then
  USB_DEVICE_FLAG=("--device" "/dev/bus/usb")
  echo "Info: USB device passthrough enabled (/dev/bus/usb)" >&2
else
  echo "Info: USB device passthrough unavailable (not Linux or no USB devices)" >&2
fi

API_KEY_ENV=()
if [[ -n "$ANTHROPIC_API_KEY" ]]; then
  API_KEY_ENV=("-e" "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
  echo "Info: Passing through ANTHROPIC_API_KEY for Claude Code authentication" >&2
fi

# Write the mounts map to a temp file; it will be mounted as ~/mounts inside the container
MOUNTS_TMPFILE=$(mktemp)
printf "%b" "$MOUNTS_CONTENT" > "$MOUNTS_TMPFILE"

echo "Mounting (read-write): $(pwd) -> /${DIR_NAME} (workspace)" >&2

podman run -it --rm \
  "${USERNS_FLAG[@]}" \
  "${USB_DEVICE_FLAG[@]}" \
  "${DEVICE_MOUNTS[@]}" \
  "${GROUP_ADD_FLAG[@]}" \
  -v "$(pwd):/${DIR_NAME}" \
  "${DOTFILES_MOUNT[@]}" \
  "${CLAUDE_MOUNT[@]}" \
  "${NPM_CACHE_MOUNT[@]}" \
  "${VOLUME_MOUNTS[@]}" \
  "${API_KEY_ENV[@]}" \
  -v "${MOUNTS_TMPFILE}:/home/developer/mounts:ro" \
  -e HOST_UID=$(id -u) \
  -e HOST_GID=$(id -g) \
  -w "/${DIR_NAME}" \
  localdev:latest \
  bash

rm -f "$MOUNTS_TMPFILE"
