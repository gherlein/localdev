#!/bin/bash
# Pull the latest localdev container image

REGISTRY=ghcr.io
REPO=gherlein
IMAGE_DEV=${REGISTRY}/${REPO}/localdev
TAG=latest

# Detect container runtime
if command -v podman >/dev/null 2>&1; then
    RUNTIME=podman
elif command -v docker >/dev/null 2>&1; then
    RUNTIME=docker
else
    echo "Error: Neither podman nor docker found in PATH" >&2
    echo "Please install podman or docker first" >&2
    exit 1
fi

echo "Pulling ${IMAGE_DEV}:${TAG} using ${RUNTIME}..."
${RUNTIME} pull ${IMAGE_DEV}:${TAG}

if [ $? -eq 0 ]; then
    echo "Successfully pulled ${IMAGE_DEV}:${TAG}"
else
    echo "Error: Failed to pull ${IMAGE_DEV}:${TAG}" >&2
    exit 1
fi
